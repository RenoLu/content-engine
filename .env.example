# ============================================================================
# Content Engine — environment configuration
# Copy this file to `.env` and fill in the values you need.
# Secrets live here; non-secret tunables live in config/config.toml.
# ============================================================================

# ---- Safety: publishing mode ----------------------------------------------
# dry_run  -> generate + review + simulate publishing, write output locally, NEVER post externally (DEFAULT)
# live     -> publish externally, but ONLY if the reviewer approves
PUBLISH_MODE=dry_run

# ---- Post image (article-specific, free via Pollinations) ------------------
# Each post gets an image illustrating that article: DEV.to cover, Bluesky embed,
# Mastodon media. No API key (Pollinations/Flux). Prompt comes from the draft's
# image_prompt (authored) or is derived from the title/angle. Set false to disable.
POST_IMAGE=true
POST_IMAGE_WIDTH=1280
POST_IMAGE_HEIGHT=720

# ---- AI model provider -----------------------------------------------------
# One of: mock | openai | anthropic
# `mock` requires no API key and lets the full pipeline run offline (great for tests/first run).
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional model overrides (sane defaults are baked into config.toml):
OPENAI_MODEL=
ANTHROPIC_MODEL=

# ---- Source: GitHub --------------------------------------------------------
# A token is optional but strongly recommended: it raises the Search API rate
# limit from 10 to 30 requests/minute and avoids 60 req/hr core throttling.
# Use a fine-grained PAT with public-repo read access (no scopes needed for public data).
GITHUB_TOKEN=

# ---- Storage / output ------------------------------------------------------
# Defaults (data/content_engine.sqlite3 and output/) are fine for local runs.
DB_PATH=
OUTPUT_DIR=

# ---- Publishers ------------------------------------------------------------
# Comma-separated list of publishers to run. The `dryrun` publisher is always
# safe. Add real ones only once their credentials below are filled in.
# Available: dryrun,devto,ghost,wordpress,hashnode,bluesky,mastodon,linkedin,threads
ENABLED_PUBLISHERS=dryrun

# DEV.to (Forem) — Settings > Extensions > DEV Community API Keys
DEVTO_API_KEY=
# Publish as draft (true) or live article (false) when in live mode:
DEVTO_PUBLISHED=false

# Ghost Admin API — Integrations > Custom integration. Format: "id:secret"
GHOST_ADMIN_API_URL=
GHOST_ADMIN_API_KEY=
GHOST_POST_STATUS=draft

# WordPress (self-hosted) — Users > Application Passwords
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
WORDPRESS_POST_STATUS=draft

# Hashnode — gql.hashnode.com, Personal Access Token + your publication id
HASHNODE_API_KEY=
HASHNODE_PUBLICATION_ID=

# Bluesky (AT Protocol) — your handle + an app password (Settings > App Passwords)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
BLUESKY_PDS_URL=https://bsky.social

# Mastodon — an access token from your instance (Preferences > Development > New application)
MASTODON_BASE_URL=
MASTODON_ACCESS_TOKEN=
MASTODON_VISIBILITY=public

# LinkedIn — OAuth2 access token with w_member_social + the member URN
# (Posting via API requires an approved LinkedIn developer app; see API_FINDINGS.md)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
# LinkedIn-Version header (YYYYMM); bump as LinkedIn rolls API versions.
LINKEDIN_API_VERSION=202506

# Threads (Meta) — long-lived access token with threads_content_publish
# (Requires an approved Meta app; see API_FINDINGS.md)
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ---- Outreach: engagement automation (like/follow/reply) -------------------
# Separate from content publishing. Reuses BLUESKY_*/MASTODON_*/ANTHROPIC_* above.
# Safe by default: dry_run discovers + drafts but never acts.
OUTREACH_MODE=dry_run           # dry_run | live
OUTREACH_ENABLED=true           # kill switch: false halts everything
OUTREACH_APPROVAL=false         # true = draft only (log as pending_approval), never act
OUTREACH_PLATFORMS=bluesky,mastodon,devto
# Optional overrides (defaults live in config.toml [outreach]):
OUTREACH_QUERIES=               # comma-separated topic queries (empty = config default)
OUTREACH_PER_QUERY_LIMIT=15
OUTREACH_CAP_SCALE=1            # scale every per-platform daily cap (e.g. 0.5 to halve)
OUTREACH_LIKE_RATIO=0.8
OUTREACH_REPLY_RATIO=0.35
OUTREACH_SEED=1337
